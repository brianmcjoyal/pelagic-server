#!/usr/bin/env bash
# Tracked pre-push hook — activated via `git config core.hooksPath .githooks`
# (run once per clone, or use scripts/install_hooks.sh).
# Aborts `git push` if any inline dashboard JS block has a syntax error.
# Bypass (only when truly needed): git push --no-verify
set -e
cd "$(git rev-parse --show-toplevel)"
echo "[pre-push] Running scripts/check_js.py..."
/usr/bin/python3 scripts/check_js.py
echo "[pre-push] OK — pushing"
